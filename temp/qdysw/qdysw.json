    },
    "ruleContent": {
        "content": "<js>\nlet iframeSrc = result.match(/src=\"(\\/player\\.html\\?nid=\\d+&cid=\\d+[^\"]*)\"/);\nif(iframeSrc) {\n    let playerUrl = 'https://www.qdysw.com' + iframeSrc[1];\n    let playerHtml = java.ajax(playerUrl);\n    let audioUrl = playerHtml.match(/url\\d+\\s*=\\s*'([^']+)'/);\n    if(audioUrl) {\n        return audioUrl[1] + '.mp3';\n    }\n}\nreturn '';\n</js>",
