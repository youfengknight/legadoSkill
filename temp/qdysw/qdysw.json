    "ruleBookInfo": {
        "author": "<js>\nlet result = '';\nlet match = baseUrl.match(/book\\/(\\d+)\\.html/);\nif(match) {\n    let html = java.ajax(baseUrl);\n    let dd = html.match(/<dd[^>]*>\\s*<span>演播[\\s\\S]*?<\\/dd>/);\n    if(dd) {\n        let authors = dd[0].match(/<a[^>]*>([^<]*)<\\/a>/g);\n        if(authors) {\n            result = authors.map(a => a.replace(/<[^>]*>/g, '')).join('、');\n        }\n    }\n}\nresult;\n</js>",
        "coverUrl": "div.book-img img@src",
        "intro": "div.book-des@text",
        "kind": "div.book-info dl dd a@text@get:{0}",
        "lastChapter": "div.playlist li a@text@get:{0}",
        "name": "h1.book-title@text",
        "wordCount": "",
        "tocUrl": ""
    },
    "ruleToc": {
